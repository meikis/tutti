{
  "schemaVersion": "tutti.app.cli.v1",
  "scope": "automation",
  "description": "Schedule and review recurring automation runs.",
  "documentation": {
    "file": "COMMANDS.md"
  },
  "commands": [
    {
      "path": ["list"],
      "summary": "List automations",
      "description": "List automation definitions.",
      "output": {
        "defaultMode": "table",
        "json": true,
        "table": {
          "columns": [
            { "key": "id", "label": "ID" },
            { "key": "name", "label": "Name" },
            { "key": "enabled", "label": "Enabled" },
            { "key": "schedule", "label": "Schedule" },
            { "key": "next-run", "label": "Next run" },
            { "key": "active-run", "label": "Active run" },
            { "key": "unreviewed", "label": "Unreviewed" }
          ]
        }
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/list",
        "timeoutMs": 30000
      }
    },
    {
      "path": ["get"],
      "summary": "Get an automation",
      "description": "Get one automation definition by id or exact name.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "automation-id": {
            "type": "string",
            "description": "Automation id to read."
          },
          "name": {
            "type": "string",
            "description": "Exact automation name to read when automation-id is omitted."
          }
        }
      },
      "output": {
        "defaultMode": "json",
        "json": true
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/get",
        "timeoutMs": 30000
      }
    },
    {
      "path": ["create"],
      "summary": "Create an automation",
      "description": "Create an automation definition.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Automation name."
          },
          "prompt": {
            "type": "string",
            "description": "Prompt to send to the runner."
          },
          "cwd": {
            "type": "string",
            "description": "Working directory. Defaults to the workspace root."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether scheduled runs are enabled."
          },
          "schedule-type": {
            "type": "string",
            "description": "Schedule type: manual, interval, daily, weekly, or cron."
          },
          "interval-minutes": {
            "type": "integer",
            "description": "Interval schedule in minutes."
          },
          "time-of-day": {
            "type": "string",
            "description": "Daily or weekly run time in HH:MM."
          },
          "days-of-week": {
            "type": "string",
            "description": "Comma-separated ISO weekdays for weekly schedules, 1=Monday through 7=Sunday."
          },
          "cron": {
            "type": "string",
            "description": "Five-field cron expression for cron schedules."
          },
          "concurrency": {
            "type": "string",
            "description": "Concurrent run policy: skip, queue, or replace."
          },
          "provider": {
            "type": "string",
            "description": "Agent provider id, such as codex, claude-code, or gemini."
          },
          "model": {
            "type": "string",
            "description": "Runner model id."
          },
          "reasoning-effort": {
            "type": "string",
            "description": "Runner reasoning effort."
          },
          "permission-mode": {
            "type": "string",
            "description": "Runner permission mode."
          },
          "runner-args": {
            "type": "string",
            "description": "Additional runner args, parsed with shell-style quoting."
          },
          "env": {
            "type": "string",
            "description": "Comma-separated KEY=VALUE environment variables."
          }
        },
        "required": ["name", "prompt"]
      },
      "output": {
        "defaultMode": "json",
        "json": true
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/create",
        "timeoutMs": 30000
      }
    },
    {
      "path": ["update"],
      "summary": "Update an automation",
      "description": "Update one automation definition by id. Omitted fields keep their current values.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "automation-id": {
            "type": "string",
            "description": "Automation id to update."
          },
          "name": {
            "type": "string",
            "description": "Automation name."
          },
          "prompt": {
            "type": "string",
            "description": "Prompt to send to the runner."
          },
          "cwd": {
            "type": "string",
            "description": "Working directory."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether scheduled runs are enabled."
          },
          "schedule-type": {
            "type": "string",
            "description": "Schedule type: manual, interval, daily, weekly, or cron."
          },
          "interval-minutes": {
            "type": "integer",
            "description": "Interval schedule in minutes."
          },
          "time-of-day": {
            "type": "string",
            "description": "Daily or weekly run time in HH:MM."
          },
          "days-of-week": {
            "type": "string",
            "description": "Comma-separated ISO weekdays for weekly schedules, 1=Monday through 7=Sunday."
          },
          "cron": {
            "type": "string",
            "description": "Five-field cron expression for cron schedules."
          },
          "concurrency": {
            "type": "string",
            "description": "Concurrent run policy: skip, queue, or replace."
          },
          "provider": {
            "type": "string",
            "description": "Agent provider id, such as codex, claude-code, or gemini."
          },
          "model": {
            "type": "string",
            "description": "Runner model id."
          },
          "reasoning-effort": {
            "type": "string",
            "description": "Runner reasoning effort."
          },
          "permission-mode": {
            "type": "string",
            "description": "Runner permission mode."
          },
          "runner-args": {
            "type": "string",
            "description": "Additional runner args, parsed with shell-style quoting."
          },
          "env": {
            "type": "string",
            "description": "Comma-separated KEY=VALUE environment variables."
          }
        },
        "required": ["automation-id"]
      },
      "output": {
        "defaultMode": "json",
        "json": true
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/update",
        "timeoutMs": 30000
      }
    },
    {
      "path": ["delete"],
      "summary": "Delete an automation",
      "description": "Delete one automation definition and its run history by id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "automation-id": {
            "type": "string",
            "description": "Automation id to delete."
          }
        },
        "required": ["automation-id"]
      },
      "output": {
        "defaultMode": "json",
        "json": true
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/delete",
        "timeoutMs": 30000
      }
    },
    {
      "path": ["run"],
      "summary": "Run an automation",
      "description": "Trigger one automation immediately by id or exact name.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "automation-id": {
            "type": "string",
            "description": "Automation id to run."
          },
          "name": {
            "type": "string",
            "description": "Exact automation name to run when automation-id is omitted."
          }
        }
      },
      "output": {
        "defaultMode": "json",
        "json": true
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/run",
        "timeoutMs": 30000
      }
    },
    {
      "path": ["runs"],
      "summary": "List automation runs",
      "description": "List recent automation runs, optionally filtered by automation id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "automation-id": {
            "type": "string",
            "description": "Automation id to filter runs."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of runs to return."
          }
        }
      },
      "output": {
        "defaultMode": "table",
        "json": true,
        "table": {
          "columns": [
            { "key": "id", "label": "ID" },
            { "key": "automation-id", "label": "Automation" },
            { "key": "run-status", "label": "Run status" },
            { "key": "task-status", "label": "Task status" },
            { "key": "trigger", "label": "Trigger" },
            { "key": "queued", "label": "Queued" },
            { "key": "finished", "label": "Finished" }
          ]
        }
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/runs",
        "timeoutMs": 30000
      }
    },
    {
      "path": ["complete-run"],
      "summary": "Submit an automation run status",
      "description": "Submit the final structured status for the current automation run.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "run-id": {
            "type": "string",
            "description": "Automation run id to complete."
          },
          "status": {
            "type": "string",
            "description": "Automation result status: success, fail, or skip."
          }
        },
        "required": ["run-id", "status"]
      },
      "output": {
        "defaultMode": "json",
        "json": true
      },
      "handler": {
        "kind": "http",
        "method": "POST",
        "path": "/tutti/cli/complete-run",
        "timeoutMs": 30000
      }
    }
  ]
}
