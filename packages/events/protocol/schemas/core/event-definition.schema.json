{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tutti.dev/schemas/events/event-definition.schema.json",
  "title": "BusinessEventDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic",
    "version",
    "direction",
    "owner",
    "scope",
    "payloadSchema"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)+$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "direction": {
      "type": "string",
      "enum": ["client->server", "server->client"]
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+([.-][a-z0-9]+)*$"
    },
    "scope": {
      "type": "string",
      "enum": ["global", "desktop", "workspace"]
    },
    "payloadSchema": {
      "type": "object"
    }
  }
}
