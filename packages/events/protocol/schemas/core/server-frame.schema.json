{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tutti.dev/schemas/events/server-frame.schema.json",
  "title": "BusinessEventServerFrame",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "protocolVersion", "catalogRevision", "serverTime"],
      "properties": {
        "kind": {
          "const": "ready"
        },
        "protocolVersion": {
          "const": 1
        },
        "catalogRevision": {
          "type": "string",
          "minLength": 1
        },
        "serverTime": {
          "type": "string",
          "minLength": 1,
          "format": "date-time"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "requestId", "acceptedAt"],
      "properties": {
        "kind": {
          "const": "ack"
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "acceptedAt": {
          "type": "string",
          "minLength": 1,
          "format": "date-time"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "event"],
      "properties": {
        "kind": {
          "const": "event"
        },
        "event": {
          "$ref": "./event-envelope.schema.json"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "code", "message"],
      "properties": {
        "kind": {
          "const": "error"
        },
        "requestId": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9_]+$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "requestId", "sentAt"],
      "properties": {
        "kind": {
          "const": "pong"
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        },
        "sentAt": {
          "type": "string",
          "minLength": 1,
          "format": "date-time"
        }
      }
    }
  ]
}
