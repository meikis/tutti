{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tutti.dev/schemas/events/event-envelope.schema.json",
  "title": "BusinessEventEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "topic", "version", "emittedAt", "payload"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9]+)+$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "emittedAt": {
      "type": "string",
      "minLength": 1,
      "format": "date-time"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspaceId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "payload": true
  }
}
