{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tutti.dev/schemas/ui-system-components.schema.json",
  "title": "Tutti UI System Component Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "components"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "layer",
          "name",
          "export",
          "from",
          "category",
          "status",
          "source",
          "description",
          "useCases",
          "migrationHints"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "layer": {
            "type": "string",
            "enum": ["base", "business"]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "export": {
            "type": "string",
            "minLength": 1
          },
          "from": {
            "type": "string",
            "enum": [
              "@tutti-os/ui-system",
              "@tutti-os/ui-system/components",
              "@tutti-os/ui-system/icons",
              "@tutti-os/ui-system/styles.css",
              "@tutti-os/ui-system/utils"
            ]
          },
          "category": {
            "type": "string",
            "enum": [
              "primitive",
              "composition",
              "icon",
              "style-entry",
              "utility"
            ]
          },
          "iconVariant": {
            "type": "string",
            "enum": ["lined", "filled"]
          },
          "status": {
            "type": "string",
            "enum": ["experimental", "stable", "deprecated"]
          },
          "source": {
            "type": "string",
            "pattern": "^src/"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "propsType": {
            "type": "string",
            "minLength": 1
          },
          "useCases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "migrationHints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "storyboard": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
