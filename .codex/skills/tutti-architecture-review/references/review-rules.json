{
  "version": 1,
  "tasks": [
    {
      "id": "repo-structure",
      "title": "Repo Structure Reviewer",
      "area": "repository",
      "priority": 10,
      "pathRules": [
        { "type": "exact", "value": "AGENTS.md" },
        { "type": "exact", "value": "pnpm-workspace.yaml" },
        { "type": "exact", "value": "package.json" },
        { "type": "prefix", "value": ".github/" },
        { "type": "prefix", "value": "docs/architecture/" },
        { "type": "prefix", "value": "docs/conventions/" },
        { "type": "newTopLevelArea" },
        { "type": "packageManifest" }
      ],
      "referenceFiles": [
        "AGENTS.md",
        "docs/architecture/project-structure.md",
        "docs/conventions/README.md",
        ".codex/skills/tutti-architecture-review/references/tutti-layering.md"
      ],
      "focus": [
        "Top-level ownership across apps, services, packages, config, tools, and docs.",
        "Whether new directories represent durable ownership rather than speculative structure.",
        "Whether a new or changed package has a real shared seam and a narrow interface.",
        "Whether business logic is moving away from services/tuttid into an app or generic package."
      ]
    },
    {
      "id": "desktop-layering",
      "title": "Desktop Layering Reviewer",
      "area": "apps/desktop",
      "priority": 20,
      "pathRules": [{ "type": "prefix", "value": "apps/desktop/" }],
      "referenceFiles": [
        "AGENTS.md",
        "apps/desktop/AGENTS.md",
        "docs/conventions/desktop-layering.md",
        "docs/conventions/desktop-visual-language.md",
        "docs/conventions/ui-system.md",
        ".codex/skills/tutti-architecture-review/references/tutti-layering.md"
      ],
      "focus": [
        "main/preload/renderer/shared responsibility direction.",
        "Whether apps/desktop is becoming a second business core.",
        "Renderer feature service ownership and services/internal privacy.",
        "Typed preload API usage instead of direct Electron, daemon client, or transport access from renderer.",
        "User-visible copy and UI-system ownership when UI files change."
      ]
    },
    {
      "id": "tuttid-layering",
      "title": "Tuttid Layering Reviewer",
      "area": "services/tuttid",
      "priority": 30,
      "pathRules": [{ "type": "prefix", "value": "services/tuttid/" }],
      "referenceFiles": [
        "AGENTS.md",
        "services/tuttid/AGENTS.md",
        "docs/conventions/tuttid-layering.md",
        "docs/conventions/api-contracts.md",
        "docs/conventions/local-state-storage.md",
        ".codex/skills/tutti-architecture-review/references/tutti-layering.md"
      ],
      "focus": [
        "api/service/biz/data ownership and dependency direction.",
        "Whether business workflows, persistence, and transport concerns are placed in the owning layer.",
        "Whether the OpenAPI source changes before daemon HTTP contract implementation changes.",
        "Whether tests live at the layer they validate.",
        "Whether a new seam is real or only a shallow pass-through."
      ]
    },
    {
      "id": "package-boundaries",
      "title": "Package Boundary Reviewer",
      "area": "packages",
      "priority": 40,
      "pathRules": [{ "type": "prefix", "value": "packages/" }],
      "referenceFiles": [
        "AGENTS.md",
        "packages/AGENTS.md",
        "docs/architecture/project-structure.md",
        "docs/conventions/ui-system.md",
        ".codex/skills/tutti-architecture-review/references/tutti-layering.md"
      ],
      "focus": [
        "Whether package changes represent a real multi-consumer seam.",
        "Whether package names are narrow and responsibility-based.",
        "Whether UI package changes preserve root exports and avoid exposing internal layout.",
        "Whether business workflows are leaking into shared packages."
      ]
    },
    {
      "id": "business-event-stream",
      "title": "Business Event Stream Reviewer",
      "area": "events",
      "priority": 45,
      "pathRules": [
        { "type": "prefix", "value": "packages/events/" },
        { "type": "prefix", "value": "services/tuttid/api/events/" },
        { "type": "prefix", "value": "services/tuttid/service/eventstream/" },
        { "type": "exact", "value": "services/tuttid/api/routes.go" },
        {
          "type": "exact",
          "value": "packages/clients/tuttid-ts/src/eventStreamClient.ts"
        },
        {
          "type": "exact",
          "value": "docs/architecture/business-event-stream.md"
        }
      ],
      "referenceFiles": [
        "AGENTS.md",
        "packages/AGENTS.md",
        "services/tuttid/AGENTS.md",
        "docs/architecture/business-event-stream.md",
        ".codex/skills/tutti-architecture-review/references/tutti-layering.md"
      ],
      "focus": [
        "Whether new event-center, event-bus, pub-sub, or WebSocket coordination infrastructure duplicates the shared business event stream.",
        "Whether the existing `global`, `desktop`, and `workspace` scope modules are considered before adding a new event-center seam.",
        "Whether tuttid remains the business authority for domain-state events while desktop publishes only typed intents."
      ]
    },
    {
      "id": "contracts-and-generated-sources",
      "title": "Contracts And Generated Sources Reviewer",
      "area": "contracts",
      "priority": 50,
      "pathRules": [
        { "type": "exact", "value": "config/tutti.defaults.json" },
        { "type": "prefix", "value": "config/" },
        { "type": "contains", "value": "/generated/" },
        {
          "type": "exact",
          "value": "services/tuttid/api/openapi/tuttid.v1.yaml"
        },
        { "type": "prefix", "value": "services/tuttid/api/openapi/" },
        { "type": "suffix", "value": "pnpm-lock.yaml" },
        { "type": "suffix", "value": "package.json" },
        { "type": "contains", "value": "/i18n/" },
        { "type": "prefix", "value": "tools/scripts/" },
        { "type": "prefix", "value": "docs/conventions/" }
      ],
      "referenceFiles": [
        "AGENTS.md",
        "docs/conventions/api-contracts.md",
        "docs/conventions/runtime-overrides.md",
        "docs/conventions/local-git-hooks.md",
        "docs/conventions/static-analysis.md",
        ".codex/skills/tutti-architecture-review/references/tutti-layering.md"
      ],
      "focus": [
        "Whether source-of-truth files changed before generated outputs or contract consumers.",
        "Whether environment override growth is documented.",
        "Whether i18n and user-visible copy rules are preserved.",
        "Whether repository-managed checks update durable convention docs when the check behavior changes."
      ]
    },
    {
      "id": "cross-cutting-architecture",
      "title": "Cross-Cutting Architecture Reviewer",
      "area": "cross-cutting",
      "priority": 60,
      "requiresCrossCuttingTrigger": true,
      "pathRules": [
        {
          "type": "exact",
          "value": "services/tuttid/api/openapi/tuttid.v1.yaml"
        },
        { "type": "prefix", "value": "services/tuttid/api/generated/" },
        { "type": "prefix", "value": "services/tuttid/api/routes" },
        { "type": "prefix", "value": "services/tuttid/api/" },
        { "type": "prefix", "value": "services/tuttid/service/" },
        { "type": "prefix", "value": "apps/desktop/src/shared/contracts/" },
        { "type": "prefix", "value": "apps/desktop/src/preload/" },
        { "type": "prefix", "value": "apps/desktop/src/main/ipc/" },
        {
          "type": "prefix",
          "value": "packages/clients/tuttid-ts/src/generated/"
        },
        { "type": "suffix", "value": "package.json" },
        { "type": "packageManifest" }
      ],
      "referenceFiles": [
        "AGENTS.md",
        "docs/architecture/project-structure.md",
        "docs/conventions/desktop-layering.md",
        "docs/conventions/tuttid-layering.md",
        ".codex/skills/tutti-architecture-review/references/tutti-layering.md"
      ],
      "focus": [
        "Whether changes spanning areas preserve a single business core in services/tuttid.",
        "Whether desktop and daemon communicate through contracts instead of duplicated domain behavior.",
        "Whether shared abstractions improve locality and leverage rather than spreading shallow modules.",
        "Whether the changed seams are named after durable domain concepts."
      ]
    }
  ],
  "signals": [
    {
      "id": "renderer-direct-platform-import",
      "severity": "high",
      "taskIds": ["desktop-layering", "cross-cutting-architecture"],
      "pathRules": [
        { "type": "prefix", "value": "apps/desktop/src/renderer/" }
      ],
      "lineRegex": "from\\s+[\"'](?:electron|node:|@electron/)|require\\([\"']electron",
      "message": "Renderer code appears to import Electron or Node directly."
    },
    {
      "id": "renderer-imports-daemon-client-package",
      "severity": "medium",
      "taskIds": ["desktop-layering", "cross-cutting-architecture"],
      "pathRules": [
        { "type": "prefix", "value": "apps/desktop/src/renderer/" }
      ],
      "lineRegex": "from\\s+[\"']@tutti/client-tuttid-ts|[\"']@tutti/client-tuttid-ts[\"']",
      "message": "Renderer code imports the daemon client package. Verify this is contract/type usage and not daemon client construction."
    },
    {
      "id": "renderer-feature-internal-import",
      "severity": "medium",
      "taskIds": ["desktop-layering"],
      "pathRules": [
        { "type": "prefix", "value": "apps/desktop/src/renderer/" }
      ],
      "excludePathContains": ["/services/internal/"],
      "lineRegex": "services/internal",
      "message": "Renderer code references a feature services/internal path outside that internal implementation."
    },
    {
      "id": "data-imports-api",
      "severity": "high",
      "taskIds": ["tuttid-layering"],
      "pathRules": [{ "type": "prefix", "value": "services/tuttid/data/" }],
      "lineRegex": "services/tuttid/api|/api/|from\\s+[\"'].*api",
      "message": "Data layer appears to depend on the API layer."
    },
    {
      "id": "biz-imports-outer-layer",
      "severity": "high",
      "taskIds": ["tuttid-layering"],
      "pathRules": [{ "type": "prefix", "value": "services/tuttid/biz/" }],
      "lineRegex": "services/tuttid/(?:api|service|data)|/(?:api|service|data)/",
      "message": "Biz layer appears to depend on api, service, or data."
    },
    {
      "id": "possible-hardcoded-user-copy",
      "severity": "low",
      "taskIds": ["desktop-layering", "contracts-and-generated-sources"],
      "pathRules": [{ "type": "prefix", "value": "apps/desktop/" }],
      "excludePathContains": ["/i18n/"],
      "fileExtensions": [".ts", ".tsx"],
      "lineRegex": "\\b(?:throw new Error|title|label|message|description|placeholder)\\s*[:=]\\s*[\"'][A-Za-z][^\"']{8,}[\"']",
      "message": "Possible user-visible string outside the desktop i18n layer. Verify whether it is product copy."
    },
    {
      "id": "possible-duplicate-event-infra",
      "severity": "medium",
      "taskIds": [
        "desktop-layering",
        "tuttid-layering",
        "package-boundaries",
        "business-event-stream",
        "cross-cutting-architecture"
      ],
      "pathRules": [
        { "type": "prefix", "value": "apps/" },
        { "type": "prefix", "value": "services/" },
        { "type": "prefix", "value": "packages/" }
      ],
      "excludePathContains": [
        "packages/events/protocol/",
        "services/tuttid/api/events/",
        "services/tuttid/service/eventstream/",
        "packages/clients/tuttid-ts/src/eventStreamClient"
      ],
      "fileExtensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".go"],
      "lineRegex": "\\b(?:EventBus|EventCenter|EventHub|PubSub|createEventStream|eventSocket)\\b|event bus|event center|pub-sub|pubsub",
      "message": "New event-center or pub-sub infrastructure may duplicate the shared business event stream. Verify whether the existing global/desktop/workspace scope modules should be reused."
    },
    {
      "id": "cross-area-import",
      "severity": "medium",
      "taskIds": ["repo-structure", "cross-cutting-architecture"],
      "kind": "crossAreaImport",
      "message": "Import appears to cross a top-level product area. Verify this seam is intentional."
    }
  ]
}
